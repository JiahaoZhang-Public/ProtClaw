{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "protclaw://contracts/experiment-feedback/v1",
  "title": "ExperimentFeedback",
  "description": "Wet-lab experimental results mapped back to candidates. V1 supports CSV/JSON import.",
  "type": "object",
  "required": ["feedback_id", "project_id", "candidate_id", "assay_type", "measurement"],
  "properties": {
    "feedback_id": { "type": "string" },
    "project_id": { "type": "string" },
    "candidate_id": { "type": "string" },
    "assay_type": {
      "type": "string",
      "description": "Type of experimental assay (e.g., SPR, ELISA, SEC, DSF, expression_titer)"
    },
    "measurement": {
      "type": "number",
      "description": "Numerical measurement result"
    },
    "unit": {
      "type": "string",
      "description": "Unit of measurement (e.g., nM, mg/L, celsius, AU)"
    },
    "pass_fail": {
      "type": ["string", "null"],
      "enum": ["pass", "fail", null],
      "description": "Binary pass/fail judgment if applicable"
    },
    "conditions": {
      "type": "object",
      "description": "Experimental conditions (pH, temperature, buffer, etc.)"
    },
    "notes": {
      "type": "string",
      "description": "Free-text experimental notes"
    },
    "raw_data_path": {
      "type": "string",
      "description": "Path to raw experimental data file"
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
