{
  "name": "@protclaw/contracts",
  "version": "0.1.0",
  "description": "Shared domain contracts for ProtClaw - JSON Schema source of truth with TS/Python codegen",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "codegen": "tsx scripts/generate-ts.ts && python scripts/generate-py.py",
    "codegen:check": "tsx scripts/generate-ts.ts --check && python scripts/generate-py.py --check",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
