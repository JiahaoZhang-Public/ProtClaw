# ============================================
# ProtClaw Monorepo .gitignore
# ============================================

# --- Node.js / TypeScript ---
node_modules/
dist/
.npm-cache/
.turbo/
*.tsbuildinfo

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.eggs/
build/
develop-eggs/
sdist/
var/
wheels/
share/python-wheels/
.installed.cfg
MANIFEST
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.pytest_cache/
.hypothesis/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# --- Runtime data ---
projects/
!projects/.gitkeep

# --- Secrets ---
.env
*.keys.json

# --- NanoClaw / Orchestrator runtime ---
apps/orchestrator/store/
apps/orchestrator/data/
apps/orchestrator/logs/
apps/orchestrator/groups/*
!apps/orchestrator/groups/main/
!apps/orchestrator/groups/global/
apps/orchestrator/groups/main/*
apps/orchestrator/groups/global/*
!apps/orchestrator/groups/main/CLAUDE.md
!apps/orchestrator/groups/global/CLAUDE.md
apps/orchestrator/.nanoclaw/

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- Misc ---
*.log
/site
